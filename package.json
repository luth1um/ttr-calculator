{
  "name": "ttr-calculator",
  "version": "3.0.1",
  "private": true,
  "type": "module",
  "dependencies": {
    "i18next": "25.8.18",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-http-backend": "3.0.2",
    "ttr-calculator-typescript": "2.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@playwright/test": "1.58.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxlint": "1.55.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "vitest": "4.1.0"
  },
  "scripts": {
    "start": "vite",
    "clean": "rimraf dist",
    "format": "prettier --write \"./**/*.{css,html,js,json,md,ts,tsx,yml,yaml}\"",
    "lint": "eslint . --fix --max-warnings 0",
    "build": "tsc && vite build",
    "test": "vitest run",
    "e2e": "playwright test",
    "preview": "vite preview",
    "all-checks": "npm run clean && npm run format && npm run lint && npm run build && npm run test && npm run e2e",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{css,html,js,json,md,ts,yml,yaml}": "prettier --write"
  }
}
