{
  "name": "ttr-calculator",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "clean": "node -e \"['dist', 'playwright-report', 'test-results', 'shard-selection.txt'].forEach(p => fs.rmSync(p, { recursive: true, force: true }))\"",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix --deny-warnings",
    "build": "tsc && vite build",
    "build-cloudflare-pages": "tsc && vite build --base=/",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e-ui": "playwright test --ui",
    "e2e-update-snapshots": "playwright test --update-snapshots",
    "preview": "vite preview",
    "all-checks": "npm run clean && npm run format && npm run lint && npm run build && npm run test && npm run e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "i18next": "26.3.1",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-http-backend": "4.0.0",
    "ttr-calculator-typescript": "2.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.3",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "nano-staged": "1.0.2",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  },
  "nano-staged": {
    "*.ts": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint --fix || true"
    ],
    "!(*.ts)": "oxfmt --no-error-on-unmatched-pattern"
  },
  "allowScripts": {
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
