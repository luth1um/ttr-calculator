{
  "name": "ttr-calculator",
  "version": "3.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "clean": "rimraf dist",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix --deny-warnings",
    "build": "tsc && vite build",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e-ui": "playwright test --ui",
    "e2e-update-snapshots": "playwright test --update-snapshots",
    "preview": "vite preview",
    "all-checks": "npm run clean && npm run format && npm run lint && npm run build && npm run test && npm run e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "i18next": "26.0.3",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-http-backend": "3.0.4",
    "ttr-calculator-typescript": "2.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@playwright/test": "1.59.1",
    "@types/node": "25.5.2",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "lint-staged": "16.4.0",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.2",
    "vite": "8.0.5",
    "vitest": "4.1.2"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
